# 复制为 .env 或由编排注入（勿提交真实密钥）
# —— 公网 OAuth 回调（必填，用于微信/QQ）
MASP_PUBLIC_BASE_URL=https://your-domain.example

# —— 微信开放平台（网站应用 QR 登录）
MASP_WECHAT_OPEN_APP_ID=
MASP_WECHAT_OPEN_APP_SECRET=

# —— QQ 互联
MASP_QQ_APP_ID=
MASP_QQ_APP_SECRET=

# —— 邮箱 OTP
MASP_SMTP_HOST=
MASP_SMTP_PORT=587
MASP_SMTP_USER=
MASP_SMTP_PASSWORD=
MASP_SMTP_FROM=
MASP_SMTP_TLS=1
MASP_OTP_TTL_SEC=600
MASP_OTP_PEPPER=change-me-long-random
# 开发：无 SMTP 时在日志打印验证码（生产务必关闭）
MASP_OTP_LOG_PLAINTEXT=0

# —— 邮箱魔法链接注册（/api/v1/auth/register/email/send-link）
# 需公网可达的 MASP_PUBLIC_BASE_URL（与 OAuth 相同）
# GET verify-link：未设置本项时返回 JSON（email/token）；设置则 302 至该 URL 并附带查询参数 email、token
# MASP_EMAIL_VERIFY_REDIRECT=https://your-domain.example/your-app/complete  （可选，自有前端）
# MASP_EMAIL_LINK_PEPPER=change-me-link-pepper   （可选，默认复用 MASP_OTP_PEPPER）
# 开发：无 SMTP 时在日志打印完整验证 URL（生产务必关闭）
MASP_EMAIL_LINK_LOG_PLAINTEXT=0

# —— 短信（默认 console，生产对接云厂商 HTTP API 请扩展 sms_sender.py）
MASP_SMS_BACKEND=console
